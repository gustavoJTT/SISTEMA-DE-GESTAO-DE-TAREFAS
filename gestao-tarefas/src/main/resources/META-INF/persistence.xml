<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <!-- config jpa com tomcat-->
    <persistence-unit name="gestao-tarefas-pu" transaction-type="RESOURCE_LOCAL">

        <!-- usar hibernate com jpa -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- lista automatiamente as entidades (@Entity)-->
        <exclude-unlisted-classes>false</exclude-unlisted-classes>

        <properties>

        <!-- conexaoc com o banco -->
            <property name="jakarta.persistence.jdbc.driver"
                      value="org.postgresql.Driver"/>

        <!-- url LOCAL do banco -->
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/gestao_tarefas"/>

            <property name="jakarta.persistence.jdbc.user"
                      value="gestao_user"/>
            <property name="jakarta.persistence.jdbc.password"
                      value="gestao123"/>

            <!-- config hibernate -->
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.PostgreSQLDialect"/>

            <!-- tautomatizar as tabelas -->
            <property name="hibernate.hbm2ddl.auto"
                      value="update"/>

            <!-- mostrae formata sql no terminal -->
            <!-- para debug -->
            <property name="hibernate.show_sql"
                      value="true"/>

            <property name="hibernate.format_sql"
                      value="true"/>

            <property name="hibernate.connection.charSet" 
                      value="UTF-8"/>

        </properties>
    </persistence-unit>

</persistence>
